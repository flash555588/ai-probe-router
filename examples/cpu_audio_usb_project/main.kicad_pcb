(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "3V3")
  (net 3 "HP_L")
  (net 4 "HP_R")
  (net 5 "HP_MIC")
  (net 6 "HP_GND")
  (net 7 "HP_DETECT")
  (net 8 "USB_DP")
  (net 9 "USB_DM")
  (net 10 "USB_VBUS")
  (net 11 "USB_ID")
  (net 12 "USB_GND")
  (net 13 "I2S_MCK")
  (net 14 "I2S_SCK")
  (net 15 "I2S_SD")
  (net 16 "I2S_WS")
  (net 17 "SWDIO")
  (net 18 "SWCLK")

  ;; CPU U1 - STM32F4 LQFP-64 at center
  (footprint "Package_QFP:LQFP-64"
    (layer "F.Cu")
    (at 40 25 0)
    (uuid "cpu-001")
    (property "Reference" "U1"
      (at -8 -10 0)
      (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "STM32F405"
      (at 0 10 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    ;; Left side pins
    (pad "1" smd rect (at -7.0 -5.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 17 "SWDIO") (uuid "u1-p1"))
    (pad "2" smd rect (at -7.0 -4.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 18 "SWCLK") (uuid "u1-p2"))
    (pad "3" smd rect (at -7.0 -3.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "3V3") (uuid "u1-p3"))
    (pad "4" smd rect (at -7.0 -2.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p4"))
    (pad "5" smd rect (at -7.0 -1.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "HP_L") (uuid "u1-p5"))
    (pad "6" smd rect (at -7.0 -0.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "HP_R") (uuid "u1-p6"))
    (pad "7" smd rect (at -7.0 0.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "HP_MIC") (uuid "u1-p7"))
    (pad "8" smd rect (at -7.0 1.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "HP_DETECT") (uuid "u1-p8"))
    (pad "9" smd rect (at -7.0 2.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 13 "I2S_MCK") (uuid "u1-p9"))
    (pad "10" smd rect (at -7.0 3.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 14 "I2S_SCK") (uuid "u1-p10"))
    (pad "11" smd rect (at -7.0 4.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 15 "I2S_SD") (uuid "u1-p11"))
    (pad "12" smd rect (at -7.0 5.5) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 16 "I2S_WS") (uuid "u1-p12"))
    ;; Top side pins
    (pad "13" smd rect (at -5.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p13"))
    (pad "14" smd rect (at -4.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "3V3") (uuid "u1-p14"))
    (pad "15" smd rect (at -3.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p15"))
    (pad "16" smd rect (at -2.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "USB_VBUS") (uuid "u1-p16"))
    (pad "17" smd rect (at -1.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 11 "USB_ID") (uuid "u1-p17"))
    (pad "18" smd rect (at -0.5 -7.0 90) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "USB_GND") (uuid "u1-p18"))
    ;; Right side pins
    (pad "32" smd rect (at 7.0 -5.5 180) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "USB_DP") (uuid "u1-p32"))
    (pad "33" smd rect (at 7.0 -4.5 180) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "USB_DM") (uuid "u1-p33"))
    (pad "34" smd rect (at 7.0 -3.5 180) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p34"))
    (pad "35" smd rect (at 7.0 -2.5 180) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "3V3") (uuid "u1-p35"))
    ;; Bottom side pins
    (pad "48" smd rect (at 5.5 7.0 270) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p48"))
    (pad "49" smd rect (at 4.5 7.0 270) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 2 "3V3") (uuid "u1-p49"))
    (pad "50" smd rect (at 3.5 7.0 270) (size 1.2 0.5) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "u1-p50"))
  )

  ;; 3.5mm Headphone Jack J1
  (footprint "Connector_Audio:Jack_3.5mm_CUI_SJ-3523-SMT"
    (layer "F.Cu")
    (at 10 25 0)
    (uuid "jack-001")
    (property "Reference" "J1"
      (at -5 -4 0)
      (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "Headphone"
      (at 0 4 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (pad "1" smd rect (at -2.5 -2.0) (size 2.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 5 "HP_MIC") (uuid "j1-p1"))
    (pad "2" smd rect (at -2.5 0.0) (size 2.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 6 "HP_GND") (uuid "j1-p2"))
    (pad "3" smd rect (at -2.5 2.0) (size 2.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 4 "HP_R") (uuid "j1-p3"))
    (pad "4" smd rect (at 2.5 0.0) (size 2.0 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 3 "HP_L") (uuid "j1-p4"))
    (pad "5" smd rect (at 2.5 2.5) (size 1.5 1.0) (layers "F.Cu" "F.Paste" "F.Mask") (net 7 "HP_DETECT") (uuid "j1-p5"))
  )

  ;; USB Type-C Connector J2
  (footprint "Connector_USB:USB_C_Receptacle_HRO_TYPE-C-31-M-12"
    (layer "F.Cu")
    (at 70 25 180)
    (uuid "usb-001")
    (property "Reference" "J2"
      (at 0 -5 0)
      (layer "F.SilkS")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "USB-C"
      (at 0 5 0)
      (layer "F.Fab")
      (effects (font (size 1 1) (thickness 0.15)))
    )
    ;; Top row
    (pad "A1" smd rect (at -3.5 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "USB_GND") (uuid "j2-a1"))
    (pad "A4" smd rect (at -2.0 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "USB_VBUS") (uuid "j2-a4"))
    (pad "A5" smd rect (at -1.0 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "j2-a5"))
    (pad "A6" smd rect (at 0.0 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "USB_DP") (uuid "j2-a6"))
    (pad "A7" smd rect (at 1.0 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "USB_DM") (uuid "j2-a7"))
    (pad "A9" smd rect (at 2.0 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "USB_VBUS") (uuid "j2-a9"))
    (pad "A12" smd rect (at 3.5 -2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "USB_GND") (uuid "j2-a12"))
    ;; Bottom row (mirrored due to rotation)
    (pad "B1" smd rect (at -3.5 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "USB_GND") (uuid "j2-b1"))
    (pad "B4" smd rect (at -2.0 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "USB_VBUS") (uuid "j2-b4"))
    (pad "B5" smd rect (at -1.0 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 1 "GND") (uuid "j2-b5"))
    (pad "B6" smd rect (at 0.0 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 8 "USB_DP") (uuid "j2-b6"))
    (pad "B7" smd rect (at 1.0 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 9 "USB_DM") (uuid "j2-b7"))
    (pad "B9" smd rect (at 2.0 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 10 "USB_VBUS") (uuid "j2-b9"))
    (pad "B12" smd rect (at 3.5 2.5) (size 0.6 1.2) (layers "F.Cu" "F.Paste" "F.Mask") (net 12 "USB_GND") (uuid "j2-b12"))
    ;; Shield
    (pad "S1" thru_hole circle (at -4.5 -1.5) (size 1.2 1.2) (drill 0.8) (layers *.Cu *.Mask) (net 12 "USB_GND") (uuid "j2-s1"))
    (pad "S2" thru_hole circle (at 4.5 -1.5) (size 1.2 1.2) (drill 0.8) (layers *.Cu *.Mask) (net 12 "USB_GND") (uuid "j2-s2"))
    (pad "S3" thru_hole circle (at -4.5 1.5) (size 1.2 1.2) (drill 0.8) (layers *.Cu *.Mask) (net 12 "USB_GND") (uuid "j2-s3"))
    (pad "S4" thru_hole circle (at 4.5 1.5) (size 1.2 1.2) (drill 0.8) (layers *.Cu *.Mask) (net 12 "USB_GND") (uuid "j2-s4"))
  )

  ;; Board edge - 80 x 50 mm
  (gr_rect
    (start 0 0)
    (end 80 50)
    (stroke (width 0.1) (type default))
    (fill none)
    (layer "Edge.Cuts")
    (uuid "edge-001")
  )
)
