(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user "B.Mask")
    (39 "F.Mask" user "F.Mask")
    (44 "Edge.Cuts" user)
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
  )
  (net 0 "")
  (net 1 "GND")
  (net 2 "VCC")
  (net 3 "UART_TX")
  (net 4 "UART_RX")
  (net 5 "STATE")
  (net 6 "LED")
  (net 7 "EN")

  (footprint "RF_Module:Bluetooth_HC-05"
    (layer "F.Cu")
    (at 50 50 0)
    (uuid "bt-fp-001")
    (property "Reference" "U1"
      (at -8 -11 0)
      (layer "F.SilkS")
      (hide no)
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (property "Value" "HC-05"
      (at 0 11 0)
      (layer "F.Fab")
      (hide no)
      (effects (font (size 1 1) (thickness 0.15)))
    )
    (pad "1" smd rect
      (at -6 8)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 2 "VCC")
      (uuid "bt-pad-001")
    )
    (pad "2" smd rect
      (at -6 5)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "GND")
      (uuid "bt-pad-002")
    )
    (pad "3" smd rect
      (at -6 2)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 3 "UART_TX")
      (uuid "bt-pad-003")
    )
    (pad "4" smd rect
      (at -6 -1)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 4 "UART_RX")
      (uuid "bt-pad-004")
    )
    (pad "5" smd rect
      (at -6 -4)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 5 "STATE")
      (uuid "bt-pad-005")
    )
    (pad "6" smd rect
      (at 6 8)
      (size 2 1.2)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 7 "EN")
      (uuid "bt-pad-006")
    )
  )

  (footprint "LED_SMD:LED_0603_1608Metric"
    (layer "F.Cu")
    (at 65 55 90)
    (uuid "bt-fp-002")
    (property "Reference" "D1"
      (at -2.5 0 90)
      (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (property "Value" "STATUS_LED"
      (at 2.5 0 90)
      (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (pad "1" smd rect
      (at -0.8 0)
      (size 0.9 0.9)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 1 "GND")
      (uuid "bt-pad-007")
    )
    (pad "2" smd rect
      (at 0.8 0)
      (size 0.9 0.9)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (net 6 "LED")
      (uuid "bt-pad-008")
    )
  )

  (footprint "Resistor_SMD:R_0402_1005Metric"
    (layer "F.Cu")
    (at 60 55 0)
    (uuid "bt-fp-003")
    (property "Reference" "R1"
      (at 0 -1.5)
      (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (property "Value" "1k"
      (at 0 1.5)
      (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (pad "1" smd roundrect
      (at -0.5 0)
      (size 0.6 0.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25)
      (net 2 "VCC")
      (uuid "bt-pad-009")
    )
    (pad "2" smd roundrect
      (at 0.5 0)
      (size 0.6 0.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25)
      (net 6 "LED")
      (uuid "bt-pad-010")
    )
  )

  (footprint "Connector_PinHeader_1.00mm:PinHeader_1x06_P1.00mm_Vertical"
    (layer "F.Cu")
    (at 35 50 90)
    (uuid "bt-fp-004")
    (property "Reference" "J1"
      (at -3 0 90)
      (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (property "Value" "CONN"
      (at 3 0 90)
      (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (pad "1" thru_hole circle
      (at 0 -2.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 2 "VCC")
      (uuid "bt-pad-011")
    )
    (pad "2" thru_hole circle
      (at 0 -1.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 1 "GND")
      (uuid "bt-pad-012")
    )
    (pad "3" thru_hole circle
      (at 0 -0.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 3 "UART_TX")
      (uuid "bt-pad-013")
    )
    (pad "4" thru_hole circle
      (at 0 0.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 4 "UART_RX")
      (uuid "bt-pad-014")
    )
    (pad "5" thru_hole circle
      (at 0 1.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 5 "STATE")
      (uuid "bt-pad-015")
    )
    (pad "6" thru_hole circle
      (at 0 2.5 90)
      (size 0.8 0.8)
      (drill 0.5)
      (layers "*.Cu" "*.Mask")
      (net 7 "EN")
      (uuid "bt-pad-016")
    )
  )

  (footprint "Capacitor_SMD:C_0402_1005Metric"
    (layer "F.Cu")
    (at 55 42 0)
    (uuid "bt-fp-005")
    (property "Reference" "C1"
      (at 0 -1.5)
      (layer "F.SilkS")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (property "Value" "100n"
      (at 0 1.5)
      (layer "F.Fab")
      (effects (font (size 0.8 0.8) (thickness 0.12)))
    )
    (pad "1" smd roundrect
      (at -0.5 0)
      (size 0.6 0.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25)
      (net 2 "VCC")
      (uuid "bt-pad-017")
    )
    (pad "2" smd roundrect
      (at 0.5 0)
      (size 0.6 0.5)
      (layers "F.Cu" "F.Paste" "F.Mask")
      (roundrect_rratio 0.25)
      (net 1 "GND")
      (uuid "bt-pad-018")
    )
  )

  (gr_rect
    (start 30 35)
    (end 70 65)
    (stroke (width 0.1) (type default))
    (fill none)
    (layer "Edge.Cuts")
    (uuid "bt-edge-001")
  )

  (zone
    (net 0)
    (net_name "")
    (layers "F.Cu" "B.Cu")
    (uuid "bt-keepout-001")
    (hatch edge 0.5)
    (connect_pads no)
    (min_thickness 0.25)
    (keepout
      (tracks not_allowed)
      (vias not_allowed)
      (pads not_allowed)
      (copperpour not_allowed)
      (footprints not_allowed))
    (fill yes)
    (polygon
      (pts
        (xy 62 35)
        (xy 70 35)
        (xy 70 45)
        (xy 62 45)))
  )

  (gr_text "BT-MODULE"
    (at 50 63 0)
    (layer "F.SilkS")
    (uuid "bt-label-001")
    (effects
      (font (size 1.5 1.5) (thickness 0.2))
      (justify center))
  )
)
