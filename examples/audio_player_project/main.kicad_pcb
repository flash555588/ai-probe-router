(kicad_pcb
  (version 20240108)
  (generator "pcbnew")
  (generator_version "8.0")
  (general
    (thickness 1.6)
    (legacy_teardrops no)
  )
  (paper "A4")
  (title_block
    (title "Audio Player / Handheld Console")
    (date "2026-06-08")
    (rev "v0.1")
    (company "DIY Audio Project")
  )
  (setup
    (pad_to_mask_clearance 0.05)
    (allow_soldermask_bridges_in_footprints no)
    (pcbplotparams
      (layerselection 0x00010fc_ffffffff)
      (plot_on_all_layers_selection 0x0000000_00000000)
      (disableapertmacros no)
      (usegerberextensions no)
      (usegerberattributes yes)
      (usegerberadvancedattributes yes)
      (creategerberjobfile yes)
      (dashed_line_dash_ratio 12.000000)
      (dashed_line_gap_ratio 3.000000)
      (svgprecision 4)
      (plotframeref no)
      (viasonmask no)
      (mode 1)
      (useauxorigin no)
      (hpglpennumber 1)
      (hpglpenspeed 20)
      (hpglpendiameter 15.000000)
      (pdf_front_fp_property_popups yes)
      (pdf_back_fp_property_popups yes)
      (dxfpolygonmode yes)
      (dxfimperialunits yes)
      (dxfusepcbnewfont yes)
      (psnegative no)
      (psa4output no)
      (plotreference yes)
      (plotvalue yes)
      (plotfptext yes)
      (plotinvisibletext no)
      (sketchpadsonfab no)
      (subtractmaskfromsilk no)
      (outputformat 1)
      (mirror no)
      (drillshape 1)
      (scaleselection 1)
      (outputdirectory "")
    )
  )
  ;; === Design Rules ===
  ;; Min trace: 0.1 mm
  ;; Min spacing: 0.1 mm
  ;; Min via: 0.4 mm / 0.2 mm drill
  ;; Board: 75.0 x 45.0 mm
  ;; Surface finish: ENIG
  ;; Via-in-pad: True

  (layers
    (0 "F.Cu" signal)
    (1 "In1.Cu" signal)
    (2 "In2.Cu" signal)
    (3 "In3.Cu" signal)
    (4 "In4.Cu" signal)
    (31 "B.Cu" signal)
    (32 "B.Adhes" user "B.Adhesive")
    (33 "F.Adhes" user "F.Adhesive")
    (34 "B.Paste" user)
    (35 "F.Paste" user)
    (36 "B.SilkS" user "B.Silkscreen")
    (37 "F.SilkS" user "F.Silkscreen")
    (38 "B.Mask" user)
    (39 "F.Mask" user)
    (40 "Dwgs.User" user "User.Drawings")
    (41 "Cmts.User" user "User.Comments")
    (42 "Eco1.User" user "User.Eco1")
    (43 "Eco2.User" user "User.Eco2")
    (44 "Edge.Cuts" user)
    (45 "Margin" user)
    (46 "B.CrtYd" user "B.Courtyard")
    (47 "F.CrtYd" user "F.Courtyard")
    (48 "B.Fab" user)
    (49 "F.Fab" user)
  )
  ;; === Auto-generated net classes (Audio Player) ===
  (net_class "Default" "Standard digital signals"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
  )
  (net_class "USB_DP_DM" "USB 2.0 Full-Speed differential pair"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (diff_pair_width 0.15)
    (diff_pair_gap 0.15)
    (add_net "USB_DP")
    (add_net "USB_DM")
  )
  (net_class "I2S_MCLK" "38.4MHz MCLK from TCXO to DAC, length < 10mm"
    (clearance 0.2)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "I2S_MCK")
    (add_net "MCLK_38M4")
  )
  (net_class "I2S_DATA" "I2S BCLK/SD/WS, match lengths ±2mm"
    (clearance 0.2)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "I2S_SCK")
    (add_net "I2S_SD")
    (add_net "I2S_WS")
  )
  (net_class "Analog_Audio" "DAC LPOUT/RPOUT → HP amp, L6 only,远离数字"
    (clearance 0.3)
    (trace_width 0.2)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "DAC_L+")
    (add_net "DAC_L-")
    (add_net "DAC_R+")
    (add_net "DAC_R-")
    (add_net "HP_OUT_L")
    (add_net "HP_OUT_R")
  )
  (net_class "Power_3V3_D" "Digital 3.3V power distribution"
    (clearance 0.2)
    (trace_width 0.5)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "3V3")
    (add_net "VDD_3V3_D")
    (add_net "+3.3V")
  )
  (net_class "Power_3V3_A" "Analog 3.3V, filtered from digital 3.3V via LC"
    (clearance 0.2)
    (trace_width 0.4)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "3V3A")
    (add_net "VDD_3V3_A")
    (add_net "AVCC")
    (add_net "+3.3VA")
  )
  (net_class "Power_1V8" "ES9018K2M DVDD, separate LDO"
    (clearance 0.2)
    (trace_width 0.3)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "1V8")
    (add_net "VDD_1V8")
    (add_net "DVDD")
    (add_net "+1.8V")
  )
  (net_class "Power_VBAT" "Battery power, high current for Class-D amps"
    (clearance 0.3)
    (trace_width 0.6)
    (via_dia 0.6)
    (via_drill 0.3)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "VBAT")
    (add_net "+BATT")
    (add_net "PVDD")
  )
  (net_class "Power_5V" "USB VBUS input"
    (clearance 0.2)
    (trace_width 0.5)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "VBUS")
    (add_net "VBUS_5V0")
    (add_net "+5V")
  )
  (net_class "GND_Digital" "Digital ground (L2, L4)"
    (clearance 0.2)
    (trace_width 0.5)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "GND")
    (add_net "DGND")
    (add_net "VSS")
  )
  (net_class "GND_Analog" "Analog ground (L5), single-point tie to digital GND"
    (clearance 0.3)
    (trace_width 0.4)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "AGND")
    (add_net "GND_A")
  )
  (net_class "SDIO" "SDIO CMD/CLK/D0-D3, match lengths ±1mm"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "SDIO_CMD")
    (add_net "SDIO_CLK")
    (add_net "SDIO_D0")
    (add_net "SDIO_D1")
    (add_net "SDIO_D2")
    (add_net "SDIO_D3")
  )
  (net_class "SPI_Flash" "SPI to W25Q128, short traces near MCU"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "SPI_SCK")
    (add_net "SPI_MISO")
    (add_net "SPI_MOSI")
    (add_net "FLASH_CS")
  )
  (net_class "I2C" "I2C for screen and joystick, 400kHz"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "I2C1_SCL")
    (add_net "I2C1_SDA")
    (add_net "I2C_SCL")
    (add_net "I2C_SDA")
  )
  (net_class "SWD_Debug" "SWDIO + SWCLK + NRST"
    (clearance 0.15)
    (trace_width 0.15)
    (via_dia 0.4)
    (via_drill 0.2)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "SWDIO")
    (add_net "SWCLK")
    (add_net "NRST")
  )
  (net_class "Speaker_Out" "Class-D differential output, short + thick"
    (clearance 0.3)
    (trace_width 0.5)
    (via_dia 0.5)
    (via_drill 0.25)
    (uvia_dia 0.3)
    (uvia_drill 0.1)
    (add_net "SPK_L+")
    (add_net "SPK_L-")
    (add_net "SPK_R+")
    (add_net "SPK_R-")
  )
  ;; === Auto-generated placement zones (Digital/Analog split) ===
  (zone (net 0) (net_name "") (layers "*.Cu") (tstamp "digital_region")
    (name "Digital_Region")
    (hatch edge 0.5)
    (connect_pads no)
    (min_thickness 0.15)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed) (copperpour not_allowed) (footprints not_allowed))
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 0.0 22.5) (xy 75.0 22.5) (xy 75.0 45.0) (xy 0.0 45.0)
      )
    )
  )
  (zone (net 0) (net_name "") (layers "*.Cu") (tstamp "analog_region")
    (name "Analog_Region")
    (hatch edge 0.5)
    (connect_pads no)
    (min_thickness 0.15)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed) (copperpour not_allowed) (footprints not_allowed))
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 0.0 0.0) (xy 75.0 0.0) (xy 75.0 22.5) (xy 0.0 22.5)
      )
    )
  )
  (zone (net 0) (net_name "") (layers "F.Cu") (tstamp "isolation_gap")
    (name "Isolation_Gap")
    (hatch edge 0.5)
    (connect_pads no)
    (min_thickness 0.15)
    (keepout (tracks not_allowed) (vias not_allowed) (pads not_allowed) (copperpour not_allowed) (footprints not_allowed))
    (fill yes (thermal_gap 0.5) (thermal_bridge_width 0.5))
    (polygon
      (pts
        (xy 0.0 21.0) (xy 75.0 21.0) (xy 75.0 24.0) (xy 0.0 24.0)
      )
    )
  )
  ;; === Board Edge ===
  (gr_line (start 0 0) (end 75 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 75 0) (end 75 45) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 75 45) (end 0 45) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 45) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  ;; === Digital/Analog split marker ===
  (dimension
    (type aligned)
    (layer "Dwgs.User")
    (pts (xy 2 22.5) (xy 73 22.5))
    (height -3)
    (gr_text "DIGITAL / ANALOG SPLIT" (at 37.5 18) (layer "Dwgs.User")
      (effects (font (size 2 2)))
    )
    (style (thickness 0.15) (arrow_length 1) (text_position_mode 0))
  )
)
